class Solution {
public:
    bool checkSubarraySum(vector<int>& nums, int k) {
        map<int,int> mpp;
        mpp[0]=-1;
        int presum=0;
        for(int i=0;i<nums.size();i++){
            presum+=nums[i];

            int rem= presum%k;
            if(mpp.find(rem)!= mpp.end()){
               if(i-mpp[rem]>=2)
                  return true;
            } else{
                mpp[rem]=i;
            }
        }
        return false;
    }
};
