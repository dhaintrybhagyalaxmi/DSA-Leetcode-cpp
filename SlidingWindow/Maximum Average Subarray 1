class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        int n=nums.size();
        double ans =0;
        double window=0;
        for(int i=0;i<k;i++){
            window += nums[i];
        }
        ans= window/k; 
        for(int j=k;j<n;j++){
            window += nums[j]-nums[j-k];
            ans= max(ans, window/k);
        }
        return ans ;
    }
};
