class Solution {
public:
    int helper(vector<int>& nums, int goal) {
     if(goal<0)return 0;
     int n = nums.size();
     int l=0,r=0,cnt=0,win=0;
     while(r<n){
        win+=nums[r];
        while(win>goal){
            win-=nums[l];
            l++;
        }
        cnt += (r-l+1);
        r++; 
     }
     return cnt;
    };
     int numSubarraysWithSum(vector<int>& nums, int goal) {
        return helper(nums, goal) - helper(nums, goal - 1);
    }
};
